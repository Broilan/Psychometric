{
  "name": "psychometric",
  "version": "2.0.2",
  "description": "TypeScript-first psychometric and behavioral measurement toolkit",
  "type": "module",
  "main": "./dist/psychometric.umd.cjs",
  "module": "./dist/psychometric.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/psychometric.js",
      "require": "./dist/psychometric.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Broilan/Psychometric.git"
  },
  "keywords": [
    "psychometrics",
    "psychometric",
    "behavioral",
    "measurement",
    "assessment",
    "statistics",
    "typescript"
  ],
  "author": "Tanner Eschmann",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Broilan/Psychometric/issues"
  },
  "homepage": "https://github.com/Broilan/Psychometric#readme",
  "engines": {
    "node": ">=20.18.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^1.6.1"
  }
}
